<ui:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:CheckmkPlugin.VSphereBaseImage.UI"
        x:Class="CheckmkPlugin.VSphereBaseImage.Views.CredentialDialog"
        Width="440" Height="240"
        Title="Admin-Anmeldung"
        WindowStartupLocation="CenterOwner">
  <Border BorderBrush="#3A3A3A" BorderThickness="1"
          Background="{DynamicResource KrosteBackgroundBrush}">
    <Grid RowDefinitions="40,*,Auto">
      <ui:TitleBar Grid.Row="0" Title="Admin-Anmeldung" />

      <StackPanel Grid.Row="1" Margin="16" Spacing="10">
        <TextBlock x:Name="PromptText" Foreground="#AAAAAA" TextWrapping="Wrap" />
        <StackPanel Spacing="3">
          <TextBlock Text="Benutzer (DOMAENE\Admin)" />
          <TextBox x:Name="UserBox" PlaceholderText="LHP\Admin" />
        </StackPanel>
        <StackPanel Spacing="3">
          <TextBlock Text="Passwort" />
          <TextBox x:Name="PassBox" PasswordChar="•" />
        </StackPanel>
        <TextBlock Text="Wird nur im Prozess-Memory gehalten, nicht gespeichert."
                   Foreground="#707070" FontSize="11" />
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                  Margin="16" Spacing="8">
        <Button Content="Weiter" Click="OnOkClick" Background="#123E6B" IsDefault="True" />
        <Button Content="Abbrechen" Click="OnCancelClick" IsCancel="True" />
      </StackPanel>
    </Grid>
  </Border>
</ui:ChromeWindow>
