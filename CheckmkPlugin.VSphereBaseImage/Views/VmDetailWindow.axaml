<ui:ChromeWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:CheckmkPlugin.VSphereBaseImage.UI"
        xmlns:vm="using:CheckmkPlugin.VSphereBaseImage.ViewModels"
        xmlns:models="using:CheckmkPlugin.VSphereBaseImage.Models"
        x:Class="CheckmkPlugin.VSphereBaseImage.Views.VmDetailWindow"
        x:DataType="vm:VmDetailViewModel"
        Width="820" Height="600"
        Title="VM-Details"
        WindowStartupLocation="CenterOwner">
  <Border BorderBrush="#3A3A3A" BorderThickness="1"
          Background="{DynamicResource KrosteBackgroundBrush}">
    <Grid RowDefinitions="40,Auto,Auto,*,Auto">

      <ui:TitleBar Grid.Row="0" Title="VM-Details" />

      <!-- Header: VM-Name, PowerState, RDP/Ping/Aktualisieren -->
      <Grid Grid.Row="1" Margin="16,10,16,0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock Text="{Binding Vm.Name}" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Foreground="#9AA0A6" FontSize="12">
            <Run Text="Power:" />
            <Run Text="{Binding Vm.PowerState}" />
            <Run Text="  •  VM-ID:" />
            <Run Text="{Binding Vm.Id}" />
            <Run Text="  •  CPU:" />
            <Run Text="{Binding Vm.CpuCount}" />
            <Run Text="  •  RAM:" />
            <Run Text="{Binding Vm.MemoryMiB}" />
            <Run Text="MiB" />
          </TextBlock>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
          <Button Content="RDP" Click="OnRdpClick" />
          <Button Content="Ping" Click="OnPingClick" />
          <Button Content="Aktualisieren"
                  Command="{Binding RefreshCommand}"
                  IsEnabled="{Binding !IsBusy}" />
        </StackPanel>
      </Grid>

      <!-- Guest-Info -->
      <Border Grid.Row="2" Background="#252526" CornerRadius="6"
              Padding="12,8" Margin="16,10,16,0">
        <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto,Auto"
              RowSpacing="4" ColumnSpacing="12">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Hostname:" Foreground="#9AA0A6" />
          <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GuestHostName, FallbackValue=—}" />
          <TextBlock Grid.Row="0" Grid.Column="2" Text="IP-Adresse:" Foreground="#9AA0A6" />
          <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding GuestIpAddress, FallbackValue=—}" />
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Guest-OS:" Foreground="#9AA0A6" />
          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GuestFullName, FallbackValue=—}" />
          <TextBlock Grid.Row="1" Grid.Column="2" Text="VMware-Tools:" Foreground="#9AA0A6" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding ToolsRunState, FallbackValue=—}" />
        </Grid>
      </Border>

      <!-- Snapshot-Liste -->
      <Grid Grid.Row="3" Margin="16,10,16,0" RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="Snapshots" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DataGrid Grid.Row="1" Name="SnapshotGrid"
                  ItemsSource="{Binding Snapshots}"
                  SelectedItem="{Binding SelectedSnapshot}"
                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                  CanUserResizeColumns="True" CanUserSortColumns="True">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="260" />
            <DataGridTextColumn Header="Erstellt"
                                Binding="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                Width="180" />
            <DataGridTextColumn Header="Beschreibung" Binding="{Binding Description}" Width="*" />
            <DataGridTemplateColumn Header="" Width="90">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:VmSnapshotInfo">
                  <Button Content="Loeschen"
                          Click="OnDeleteSnapshotClick"
                          Tag="{Binding}"
                          Background="#7A2D2D"
                          Margin="2" HorizontalAlignment="Center" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Grid>

      <!-- Statusleiste -->
      <Border Grid.Row="4" Background="#1B1F24" Padding="16,8">
        <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAAAA"
                   TextTrimming="CharacterEllipsis" />
      </Border>
    </Grid>
  </Border>
</ui:ChromeWindow>
