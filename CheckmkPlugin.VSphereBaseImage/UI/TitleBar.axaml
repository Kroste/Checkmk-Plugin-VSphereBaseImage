<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="using:Avalonia.Controls.Chrome"
             x:Class="CheckmkPlugin.VSphereBaseImage.UI.TitleBar"
             x:Name="Root"
             Height="40">
  <!-- Dupliziert aus dem Cockpit-Repo. ElementRole-Rollen sorgen dafuer, dass
       das OS Drag/Doppelklick nativ macht (TitleBar) und Fensterbuttons
       Klicks bekommen (User). -->
  <Border x:Name="Bar"
          Background="{DynamicResource KrosteTitleBarBrush}"
          chrome:WindowDecorationProperties.ElementRole="TitleBar">
    <Grid ColumnDefinitions="Auto,*,Auto">
      <TextBlock x:Name="TitleText" Grid.Column="0"
                 Margin="12,0,12,0" VerticalAlignment="Center"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource KrosteGoldBrush}"
                 Text="{Binding #Root.Title}" />

      <StackPanel Grid.Column="2" Orientation="Horizontal">
        <Button x:Name="MinButton" Classes="chrome" Content="—"
                chrome:WindowDecorationProperties.ElementRole="User" />
        <Button x:Name="MaxButton" Classes="chrome" Content="❐"
                chrome:WindowDecorationProperties.ElementRole="User" />
        <Button x:Name="CloseButton" Classes="chrome close" Content="✕"
                chrome:WindowDecorationProperties.ElementRole="User" />
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
